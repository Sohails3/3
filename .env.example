# Copy this file to .env and fill in your values
# Never commit .env to version control

# --- Google OAuth ---
# credentials.json and token.json go in the project root (gitignored)

# --- Add your API keys below ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AIRTABLE_API_KEY=
# NOTION_API_KEY=

# --- Strategic Fit Engine ---
# Required:
# ANTHROPIC_API_KEY=sk-ant-...
#
# Optional — enables live Companies House lookups for UK companies in Strip Profile:
# Register free at https://developer.company-information.service.gov.uk/
# COMPANIES_HOUSE_API_KEY=
#
# Optional — Data Quality & Verification (Step 2.5).
# Cross-checks the discovery longlist against live sources and flags hallucinations /
# bad figures in the report. Auto-runs when a provider is configured; otherwise skipped
# safely. Provider is auto-selected (prefers Exa); force with VERIFICATION_PROVIDER.
#
# Provider A (RECOMMENDED) — Exa web-search API. Simple key, works from the server.
# Get a key at https://exa.ai (dashboard → API keys; free tier available).
# EXA_API_KEY=
#
# Provider B — Bigdata.com via the Anthropic MCP connector. NOTE: Bigdata's access is
# OAuth-only (clerk.bigdata.com), which usually can't issue a reusable server token —
# so this typically only works if Bigdata grants you an API key / bearer token.
# BIGDATA_MCP_URL=https://mcp.bigdata.com/mcp
# BIGDATA_MCP_TOKEN=
#
# VERIFICATION_PROVIDER=auto     # auto (default) | exa | bigdata
# VERIFICATION_ENABLED=auto      # auto (default) | off
# VERIFICATION_MAX=12            # max companies cross-checked per run
